<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login | Pass Saver</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        min-height: 100vh;
        background: linear-gradient(to top right, rgba(0, 0, 0, 0.6), rgba(17, 17, 17, 0.8)),
            url('https://images.unsplash.com/photo-1518384401463-d3876163c195?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTR8fG5vdGVzJTIwYW5kJTIwcGVuc3xlbnwwfHwwfHx8MA%3D%3D') no-repeat center center;
        background-size: cover;
        display: flex;
        justify-content: center;
        align-items: center;
        color: #e2e8f0;
        padding: 20px;
    }

    .login-wrapper {
        background: rgba(30, 41, 59, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        width: 90vw;
        max-width: 650px;
        aspect-ratio: 1 / 1;
        padding: 60px 50px;
        box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5);
        animation: floatFadeIn 1s ease-out forwards;
        transform: translateY(30px);
        opacity: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    @keyframes floatFadeIn {
        from {
            opacity: 0;
            transform: translateY(40px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    h2 {
        text-align: center;
        font-size: 30px;
        font-weight: 700;
        color: #f9fafb;
        margin-bottom: 35px;
    }

    form {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    input {
        padding: 16px;
        background: #1e293b;
        border: 1.5px solid #334155;
        border-radius: 10px;
        color: #f1f5f9;
        font-size: 17px;
        transition: 0.3s;
    }

    input::placeholder {
        color: #94a3b8;
    }

    input:focus {
        border-color: #3b82f6;
        background-color: #0f172a;
        box-shadow: 0 0 12px #3b82f680;
        outline: none;
    }

    button {
        background-color: #3b82f6;
        color: #f8fafc;
        border: none;
        padding: 14px;
        border-radius: 10px;
        font-size: 17px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4);
        transition: all 0.3s ease;
    }

    button:hover {
        background-color: #2563eb;
        box-shadow: 0 8px 25px rgba(37, 99, 235, 0.5);
        transform: scale(1.02);
    }

    .signup-link {
        margin-top: 20px;
        text-align: center;
        font-size: 15px;
    }

    .signup-link a {
        color: #60a5fa;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s ease;
    }

    .signup-link a:hover {
        color: #93c5fd;
    }

    .error-message {
        color: #f87171;
        text-align: center;
        font-size: 14px;
    }

    @media (max-width: 768px) {
        .login-wrapper {
            width: 90%;
            padding: 40px 30px;
            aspect-ratio: unset;
        }
    }
</style>



</head>
<body>
    <div class="login-wrapper">
        <h2>Login to Your Notes</h2>

        <% if (typeof error !== 'undefined' && error.length > 0) { %>
            <p class="error-message"><%= error[0] %></p>
        <% } %>

        <form action="/login" method="POST">
            <input type="text" name="username" placeholder="Username" required />
            <input type="password" name="password" placeholder="Password" required />
            <button type="submit">Login</button>
        </form>

        <div class="signup-link">
            <p>Don’t have an account? <a href="/signup">Signup</a></p>
        </div>
    </div>
</body>
</html>
