<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Signup | Pass Saver</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      background: url('https://images.unsplash.com/photo-1709039549249-dd25168a8e63?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTZ8fHdyaXRpbmclMjBub3Rlc3xlbnwwfHwwfHx8MA%3D%3D') no-repeat center center/cover;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .signup-box {
      width: 90vw;
      max-width: 800px;
      height: 800px; /* Square shape */
      background: rgba(15, 15, 15, 0.9);
      border-radius: 20px;
      box-shadow: 0 0 30px rgba(0, 255, 255, 0.3);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 40px;
      animation: floatBox 1.5s ease-in-out forwards;
    }

    @keyframes floatBox {
      0% {
        opacity: 0;
        transform: scale(0.85) translateY(30px);
      }
      100% {
        opacity: 1;
        transform: scale(1) translateY(0);
      }
    }

    .signup-box h2 {
      color: #00f7ff;
      margin-bottom: 20px;
      font-size: 32px;
    }

    .signup-box form {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .signup-box input {
      width: 80%;
      padding: 15px;
      margin: 15px 0;
      border: none;
      border-radius: 10px;
      background: #1e1e1e;
      color: #fff;
      font-size: 18px;
      outline: none;
      transition: 0.3s;
    }

    .signup-box input:focus,
    .signup-box input:hover {
      background: #2c2c2c;
      box-shadow: 0 0 10px #00f7ff;
    }

    .signup-box button {
      width: 60%;
      padding: 15px;
      margin-top: 20px;
      border: none;
      border-radius: 10px;
      background: #00f7ff;
      color: #000;
      font-size: 20px;
      font-weight: bold;
      cursor: pointer;
      transition: background 0.3s ease, transform 0.2s ease;
    }

    .signup-box button:hover {
      background: #00c4cc;
      transform: translateY(-2px);
      box-shadow: 0 0 12px #00f7ff;
    }

    .signup-box p {
      margin-top: 30px;
      font-size: 16px;
      color: #bbb;
    }

    .signup-box a {
      color: #00f7ff;
      text-decoration: none;
      transition: 0.3s;
    }

    .signup-box a:hover {
      color: #00c4cc;
      text-shadow: 0 0 8px #00f7ff;
    }

    @media (max-width: 768px) {
      .signup-box {
        width: 90vw;
        height: 90vw;
        padding: 20px;
      }

      .signup-box h2 {
        font-size: 24px;
      }

      .signup-box input,
      .signup-box button {
        font-size: 16px;
      }
    }
  </style>
</head>
<body>
  <div class="signup-box">
    <h2>Create an Account</h2>
    <form action="/signup" method="POST">
      <input type="text" name="username" placeholder="Choose username" required />
      <input type="password" name="password" placeholder="Create password" required />
      <button type="submit">Signup</button>
    </form>
    <p>Already have an account? <a href="/login">Login</a></p>
  </div>
</body>
</html>
