<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Your Notes</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="dark">
    <div class="container">
      <div class="header">
        <h1>Your Notes</h1>
        <button id="themeToggle" type="button" >🌓</button>
      </div>

      <form id="noteForm">
        <input type="text" id="title" placeholder="Title" />
        <textarea id="content" placeholder="Write your note here..."></textarea>
        <button type="submit" id="submitBtn">Add Note</button>
      </form>
      <ul id="notesList">
        <% if (notes && notes.length > 0) { %> <% notes.forEach(note => { %>
        <li class="note">
          <div class="note-content">
            <h3><%= note.title %></h3>
            <p><%= note.content %></p>
          </div>
          <div class="note-actions">
            <button class="edit-btn" data-id="<%= note._id %>">Edit</button>
            <button class="delete-btn" data-id="<%= note._id %>">Delete</button>
          </div>
        </li>
        <% }) %> <% } else { %>
        <li>No notes yet. Start by adding one!</li>
        <% } %>
        <a href="/logout" class="logout-btn" style="color: rgb(69, 95, 118);">Logout</a>
      </ul>
    </div>
    <script src="/js/style.js"></script>
  </body>
</html>
